# OliveApp API backend - exemple de configuration
# Le script 07-api-backend.ps1 genere automatiquement .env avec les bonnes valeurs.

PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Connexion PostgreSQL (utilisateur applicatif, pas postgres)
DATABASE_URL=postgresql://oliveapp_user:CHANGE_ME@localhost:5432/oliveapp

# Secret JWT (>= 32 caracteres, genere automatiquement par le script)
JWT_SECRET=CHANGE_ME_minimum_32_caracteres_aleatoires

# CORS : "*" en dev, liste blanche en prod (separateur virgule)
CORS_ORIGIN=*

# Cout bcrypt (10 = ~100ms, 12 = ~400ms)
BCRYPT_ROUNDS=10
